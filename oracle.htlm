<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BlueSphere Consciousness | Heptagrama Gaia</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #050810;
            --bg-card: rgba(15, 23, 42, 0.6);
            --neon-blue: #00d4ff;
            --neon-cyan: #00fff9;
            --accent-red: #ff2a6d;
            --accent-orange: #ff9f1c;
            --accent-yellow: #ffc300;
            --accent-green: #2ecc71;
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
            --glass: rgba(255, 255, 255, 0.03);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 42, 109, 0.1) 0%, transparent 50%);
        }

        /* Fondo de partículas */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Header */
        header {
            position: relative;
            z-index: 10;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: linear-gradient(180deg, rgba(5,8,16,0.9) 0%, transparent 100%);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #00d4ff, #0051ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.6);
            animation: pulse 3s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 30px rgba(0, 212, 255, 0.6); }
            50% { box-shadow: 0 0 50px rgba(0, 212, 255, 0.9); }
        }

        nav {
            display: flex;
            gap: 40px;
        }

        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.3s;
            position: relative;
        }

        nav a:hover {
            color: var(--neon-blue);
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.8);
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--neon-blue);
            transition: width 0.3s;
        }

        nav a:hover::after {
            width: 100%;
        }

        /* Contenedor principal */
        .main-container {
            position: relative;
            z-index: 5;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px 40px 60px;
        }

        /* Sección Hero */
        .hero-section {
            text-align: center;
            margin-bottom: 60px;
        }

        .hero-subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 15px;
        }

        .hero-title {
            font-size: 3rem;
            font-weight: 300;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .hero-title .highlight {
            color: var(--accent-red);
            font-weight: 700;
            text-shadow: 0 0 40px rgba(255, 42, 109, 0.8);
            animation: glowRed 2s ease-in-out infinite;
        }

        @keyframes glowRed {
            0%, 100% { text-shadow: 0 0 40px rgba(255, 42, 109, 0.8); }
            50% { text-shadow: 0 0 60px rgba(255, 42, 109, 1), 0 0 80px rgba(255, 42, 109, 0.6); }
        }

        .hero-description {
            color: var(--text-secondary);
            max-width: 700px;
            margin: 0 auto 30px;
            line-height: 1.6;
        }

        /* Botones de escenario */
        .scenario-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 40px;
        }

        .scenario-btn {
            padding: 10px 25px;
            border-radius: 25px;
            border: 1px solid;
            background: transparent;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .scenario-btn.optimista {
            border-color: var(--accent-green);
            color: var(--accent-green);
        }

        .scenario-btn.optimista:hover, .scenario-btn.optimista.active {
            background: var(--accent-green);
            color: var(--bg-dark);
            box-shadow: 0 0 20px rgba(46, 204, 113, 0.5);
        }

        .scenario-btn.intermedio {
            border-color: var(--accent-yellow);
            color: var(--accent-yellow);
        }

        .scenario-btn.intermedio:hover, .scenario-btn.intermedio.active {
            background: var(--accent-yellow);
            color: var(--bg-dark);
            box-shadow: 0 0 20px rgba(255, 195, 0, 0.5);
        }

        .scenario-btn.critico {
            border-color: var(--accent-red);
            color: var(--accent-red);
        }

        .scenario-btn.critico:hover, .scenario-btn.critico.active {
            background: var(--accent-red);
            color: white;
            box-shadow: 0 0 20px rgba(255, 42, 109, 0.5);
        }

        /* Countdown Cinemático */
        .countdown-container {
            margin-bottom: 20px;
        }

        .countdown {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            font-family: 'Courier New', monospace;
        }

        .countdown-item {
            text-align: center;
        }

        .countdown-value {
            font-size: 3.5rem;
            font-weight: 700;
            background: linear-gradient(180deg, var(--neon-cyan), var(--neon-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.5);
            line-height: 1;
        }

        .countdown-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 10px;
        }

        .countdown-separator {
            font-size: 3rem;
            color: var(--neon-blue);
            animation: blink 1.5s infinite;
            margin-top: -20px;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* LEYENDA DEL COUNTDOWN */
        .countdown-legend {
            text-align: center;
            margin-top: 20px;
            margin-bottom: 60px;
            color: var(--text-secondary);
            font-size: 0.95rem;
            font-style: italic;
            letter-spacing: 0.5px;
            opacity: 0.9;
        }

        .countdown-legend::before {
            content: '🌡️ ';
        }

        /* Sección de Gauges y Dashboard */
        .dashboard-section {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 40px;
            margin-bottom: 60px;
        }

        /* Gauges Circulares */
        .gauges-container {
            display: flex;
            gap: 40px;
            justify-content: center;
            align-items: center;
        }

        .gauge-wrapper {
            position: relative;
            width: 260px;
            height: 260px;
        }

        .gauge-svg {
            transform: rotate(-90deg);
            width: 100%;
            height: 100%;
        }

        .gauge-bg {
            fill: none;
            stroke: rgba(255,255,255,0.05);
            stroke-width: 10;
        }

        .gauge-progress {
            fill: none;
            stroke: url(#gradientGauge);
            stroke-width: 10;
            stroke-linecap: round;
            stroke-dasharray: 660;
            stroke-dashoffset: 200;
            filter: drop-shadow(0 0 15px rgba(0, 212, 255, 0.8));
            animation: fillGauge 2s ease-out forwards;
        }

        @keyframes fillGauge {
            from { stroke-dashoffset: 660; }
        }

        .gauge-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .gauge-value-large {
            font-size: 3.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .gauge-label-main {
            font-size: 0.9rem;
            color: var(--text-secondary);
            max-width: 140px;
            margin-top: 5px;
            line-height: 1.3;
        }

        /* Iconos de sensores orbitando */
        .sensor-icon {
            position: absolute;
            width: 40px;
            height: 40px;
            background: var(--glass);
            border: 2px solid var(--neon-cyan);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            backdrop-filter: blur(10px);
            box-shadow: 
                0 0 20px rgba(0, 212, 255, 0.6),
                inset 0 0 10px rgba(0, 212, 255, 0.2);
            animation: sensorPulse 2s ease-in-out infinite;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .sensor-icon:hover {
            transform: scale(1.2);
            z-index: 100;
        }

        @keyframes sensorPulse {
            0%, 100% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.6); }
            50% { box-shadow: 0 0 35px rgba(0, 212, 255, 0.9); }
        }

        /* Posiciones específicas para 5 sensores (Gauge 1) */
        .gauge-wrapper[data-sensors="5"] .sensor-icon:nth-child(3) { top: -10px; left: 50%; transform: translateX(-50%); }
        .gauge-wrapper[data-sensors="5"] .sensor-icon:nth-child(4) { top: 20%; right: -5px; }
        .gauge-wrapper[data-sensors="5"] .sensor-icon:nth-child(5) { bottom: 20%; right: -5px; }
        .gauge-wrapper[data-sensors="5"] .sensor-icon:nth-child(6) { bottom: 20%; left: -5px; }
        .gauge-wrapper[data-sensors="5"] .sensor-icon:nth-child(7) { top: 20%; left: -5px; }

        /* Posiciones específicas para 2 sensores (Gauge 2) */
        .gauge-wrapper[data-sensors="2"] .sensor-icon:nth-child(3) { top: 15%; right: 0; }
        .gauge-wrapper[data-sensors="2"] .sensor-icon:nth-child(4) { bottom: 25%; right: -10px; }

        /* Panel de Métricas */
        .metrics-panel {
            background: var(--glass);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 20px;
            padding: 30px;
            backdrop-filter: blur(20px);
        }

        .metrics-title {
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
        }

        .metric-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .metric-item:last-child {
            border-bottom: none;
        }

        .metric-name {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
        }

        .metric-value {
            font-family: 'Courier New', monospace;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .metric-value.critical { color: var(--accent-red); text-shadow: 0 0 10px rgba(255, 42, 109, 0.5); }
        .metric-value.alert { color: var(--accent-orange); text-shadow: 0 0 10px rgba(255, 159, 28, 0.5); }
        .metric-value.stable { color: var(--accent-green); text-shadow: 0 0 10px rgba(46, 204, 113, 0.5); }

        /* Grid de Sensores Detallados */
        .sensors-section {
            margin-top: 40px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 600;
        }

        .section-subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .live-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--accent-green);
            font-size: 0.85rem;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            background: var(--accent-green);
            border-radius: 50%;
            animation: livePulse 1.5s infinite;
        }

        @keyframes livePulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }

        .sensors-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .sensor-card {
            background: var(--glass);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }

        .sensor-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--neon-blue);
            transform: scaleX(0);
            transition: transform 0.3s;
        }

        .sensor-card:hover::before {
            transform: scaleX(1);
        }

        .sensor-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 212, 255, 0.3);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.15);
        }

        .sensor-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            background: rgba(0,0,0,0.2);
        }

        .sensor-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sensor-icon-small {
            width: 32px;
            height: 32px;
            background: rgba(0, 212, 255, 0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sensor-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .sensor-category {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .sensor-status {
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-critical {
            background: rgba(255, 42, 109, 0.15);
            color: var(--accent-red);
            border: 1px solid var(--accent-red);
            box-shadow: 0 0 15px rgba(255, 42, 109, 0.3);
        }

        .status-alert {
            background: rgba(255, 159, 28, 0.15);
            color: var(--accent-orange);
            border: 1px solid var(--accent-orange);
            box-shadow: 0 0 15px rgba(255, 159, 28, 0.3);
        }

        .status-deterioro {
            background: rgba(255, 195, 0, 0.15);
            color: var(--accent-yellow);
            border: 1px solid var(--accent-yellow);
            box-shadow: 0 0 15px rgba(255, 195, 0, 0.3);
        }

        .status-riesgo {
            background: rgba(0, 212, 255, 0.15);
            color: var(--neon-blue);
            border: 1px solid var(--neon-blue);
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.3);
        }

        .status-stable {
            background: rgba(46, 204, 113, 0.15);
            color: var(--accent-green);
            border: 1px solid var(--accent-green);
            box-shadow: 0 0 15px rgba(46, 204, 113, 0.3);
        }

        .sensor-body {
            padding: 20px;
        }

        .sensor-value-main {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .sensor-value-main.critical { color: var(--accent-red); }
        .sensor-value-main.alert { color: var(--accent-orange); }
        .sensor-value-main.deterioro { color: var(--accent-yellow); }
        .sensor-value-main.riesgo { color: var(--neon-blue); }
        .sensor-value-main.stable { color: var(--accent-green); }

        .sensor-limit {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 15px;
        }

        .sensor-bar {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 15px;
        }

        .sensor-bar-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 1s ease-out;
        }

        .sensor-bar-fill.critical { background: var(--accent-red); box-shadow: 0 0 10px var(--accent-red); }
        .sensor-bar-fill.alert { background: var(--accent-orange); box-shadow: 0 0 10px var(--accent-orange); }
        .sensor-bar-fill.deterioro { background: var(--accent-yellow); box-shadow: 0 0 10px var(--accent-yellow); }
        .sensor-bar-fill.riesgo { background: var(--neon-blue); box-shadow: 0 0 10px var(--neon-blue); }
        .sensor-bar-fill.stable { background: var(--accent-green); box-shadow: 0 0 10px var(--accent-green); }

        .sensor-description {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .sensor-source {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 10px;
            font-style: italic;
        }

        /* === MÓDULO 1: BLUESPHERE CONSCIOUSNESS === */
        .consciousness-section {
            position: relative;
            z-index: 5;
            padding: 80px 40px;
            margin-top: 40px;
            background: linear-gradient(180deg, transparent 0%, rgba(0, 212, 255, 0.03) 50%, transparent 100%);
        }

        .consciousness-container {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }

        .consciousness-title {
            font-size: 2.5rem;
            font-weight: 300;
            letter-spacing: 3px;
            margin-bottom: 15px;
            background: linear-gradient(135deg, #ffffff 0%, var(--neon-cyan) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.3);
        }

        .consciousness-tagline {
            font-size: 1.3rem;
            color: var(--neon-cyan);
            font-weight: 500;
            margin-bottom: 40px;
            letter-spacing: 1px;
            text-shadow: 0 0 20px rgba(0, 255, 249, 0.4);
        }

        .consciousness-description {
            margin-bottom: 50px;
        }

        .consciousness-description p {
            color: var(--text-secondary);
            font-size: 1.05rem;
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .protocolo-box {
            background: var(--glass);
            border: 1px solid rgba(0, 212, 255, 0.15);
            border-radius: 20px;
            padding: 40px;
            backdrop-filter: blur(20px);
            position: relative;
            overflow: hidden;
        }

        .protocolo-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
            opacity: 0.6;
        }

        .protocolo-title {
            font-size: 1.4rem;
            color: var(--text-primary);
            margin-bottom: 15px;
            font-weight: 600;
        }

        .protocolo-text {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .protocolo-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 15px 35px;
            border: 2px solid var(--neon-cyan);
            border-radius: 30px;
            color: var(--neon-cyan);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.4s ease;
            background: transparent;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .protocolo-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 249, 0.2), transparent);
            transition: left 0.5s;
        }

        .protocolo-btn:hover::before {
            left: 100%;
        }

        .protocolo-btn:hover {
            background: var(--neon-cyan);
            color: var(--bg-dark);
            box-shadow: 0 0 40px rgba(0, 255, 249, 0.6);
            transform: translateY(-2px);
        }

        /* === MÓDULO 2: PUENTES DE CONCIENCIA === */
        .puentes-section {
            position: relative;
            z-index: 5;
            padding: 80px 40px;
            margin-top: 20px;
        }

        .puentes-container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .puentes-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .puentes-title {
            font-size: 2.2rem;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 15px;
            color: var(--text-primary);
        }

        .puentes-intro {
            color: var(--text-secondary);
            font-size: 1.05rem;
            line-height: 1.7;
            max-width: 800px;
            margin: 0 auto 30px;
        }

        .puentes-intro .highlight {
            color: var(--neon-cyan);
            font-weight: 600;
        }

        .puentes-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-bottom: 40px;
        }

        .puente-item {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 25px 30px;
            background: var(--glass);
            border: 1px solid rgba(0, 212, 255, 0.1);
            border-radius: 16px;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .puente-item:hover {
            border-color: rgba(0, 212, 255, 0.3);
            transform: translateX(10px);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.1);
        }

        .puente-icon {
            width: 50px;
            height: 50px;
            background: rgba(0, 212, 255, 0.1);
            border: 2px solid var(--neon-cyan);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
        }

        .puente-text {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.5;
        }

        .puente-text strong {
            color: var(--text-primary);
            font-weight: 600;
        }

        .regalo-box {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.05), rgba(0, 255, 249, 0.05));
            border: 2px dashed rgba(0, 212, 255, 0.3);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }

        .regalo-box::before {
            content: '📚';
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.5rem;
            background: var(--bg-dark);
            padding: 0 15px;
        }

        .regalo-text {
            color: var(--neon-cyan);
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .regalo-subtext {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        .puentes-footer {
            text-align: center;
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.6;
            max-width: 700px;
            margin: 0 auto 40px;
        }

        .puentes-cta {
            text-align: center;
        }

        .btn-puentes {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 15px 35px;
            border: 2px solid var(--accent-green);
            border-radius: 30px;
            color: var(--accent-green);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.4s ease;
            background: transparent;
            cursor: pointer;
        }

        .btn-puentes:hover {
            background: var(--accent-green);
            color: var(--bg-dark);
            box-shadow: 0 0 30px rgba(46, 204, 113, 0.5);
            transform: translateY(-2px);
        }

        /* === MÓDULO 3: TRANSFORMACIÓN === */
        .transformacion-section {
            position: relative;
            z-index: 5;
            padding: 80px 40px;
            margin-top: 20px;
            background: linear-gradient(180deg, transparent 0%, rgba(46, 204, 113, 0.03) 50%, transparent 100%);
        }

        .transformacion-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .transformacion-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .transformacion-title {
            font-size: 1.8rem;
            font-weight: 300;
            letter-spacing: 2px;
            color: var(--text-primary);
            margin-bottom: 15px;
        }

        .transformacion-title::after {
            content: '';
            display: block;
            width: 100px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
            margin: 15px auto 0;
        }

        .transformacion-subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
            margin-bottom: 50px;
            text-align: center;
        }

        .acciones-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-bottom: 50px;
        }

        .accion-card {
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            transition: all 0.4s ease;
            backdrop-filter: blur(10px);
        }

        .accion-card:hover {
            border-color: rgba(0, 212, 255, 0.3);
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.15);
        }

        .accion-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
            display: block;
        }

        .accion-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.4;
        }

        .cta-box {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(0, 255, 249, 0.05));
            border-left: 4px solid var(--neon-cyan);
            border-radius: 0 20px 20px 0;
            padding: 40px;
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
            backdrop-filter: blur(20px);
        }

        .cta-text {
            color: var(--text-primary);
            font-size: 1.2rem;
            line-height: 1.6;
            margin-bottom: 10px;
        }

        .cta-text strong {
            color: var(--neon-cyan);
        }

        .cta-subtext {
            color: var(--text-secondary);
            font-size: 1rem;
            margin-bottom: 30px;
        }

        .btn-activar {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 18px 40px;
            background: linear-gradient(135deg, var(--neon-blue), var(--neon-cyan));
            border: none;
            border-radius: 35px;
            color: var(--bg-dark);
            text-decoration: none;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.4s ease;
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.4);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .btn-activar::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.5s;
        }

        .btn-activar:hover::before {
            left: 100%;
        }

        .btn-activar:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 0 50px rgba(0, 212, 255, 0.7);
        }

        .btn-activar .icon {
            font-size: 1.3rem;
        }

        .simulador-note {
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-top: 15px;
            font-style: italic;
            opacity: 0.8;
        }

        /* === MÓDULO 4: MEMBRESÍA / LA LLAVE === */
        .membresia-section {
            position: relative;
            z-index: 5;
            padding: 100px 40px;
            margin-top: 20px;
            background: linear-gradient(180deg, transparent 0%, rgba(0, 212, 255, 0.05) 30%, rgba(0, 212, 255, 0.02) 70%, transparent 100%);
        }

        .membresia-container {
            max-width: 900px;
            margin: 0 auto;
            background: var(--glass);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 30px;
            padding: 60px;
            backdrop-filter: blur(30px);
            position: relative;
            overflow: hidden;
            box-shadow: 
                0 0 60px rgba(0, 212, 255, 0.1),
                inset 0 0 60px rgba(0, 212, 255, 0.02);
        }

        .membresia-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--neon-cyan), var(--neon-blue), var(--neon-cyan), transparent);
            opacity: 0.8;
        }

        .llave-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .llave-icon {
            font-size: 3rem;
            margin-bottom: 20px;
            display: inline-block;
            animation: keyPulse 3s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(255, 193, 7, 0.5));
        }

        @keyframes keyPulse {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 20px rgba(255, 193, 7, 0.5)); }
            50% { transform: scale(1.05); filter: drop-shadow(0 0 40px rgba(255, 193, 7, 0.8)); }
        }

        .llave-title {
            font-size: 2.2rem;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #ffffff 0%, var(--neon-cyan) 50%, var(--neon-blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .llave-subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.6;
            max-width: 600px;
            margin: 0 auto 20px;
        }

        .llave-subtitle strong {
            color: var(--neon-cyan);
            font-weight: 500;
        }

        .llave-description {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.7;
            max-width: 700px;
            margin: 0 auto 50px;
            text-align: center;
        }

        .beneficios-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-bottom: 40px;
        }

        .beneficio-card {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 20px;
            padding: 35px 25px;
            position: relative;
            transition: all 0.4s ease;
            backdrop-filter: blur(10px);
        }

        .beneficio-card:nth-child(1) {
            border-left: 4px solid var(--neon-cyan);
        }

        .beneficio-card:nth-child(2) {
            border-left: 4px solid var(--accent-green);
        }

        .beneficio-card:nth-child(3) {
            border-left: 4px solid var(--accent-orange);
        }

        .beneficio-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        .beneficio-card:nth-child(1):hover {
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.2);
        }

        .beneficio-card:nth-child(2):hover {
            box-shadow: 0 20px 40px rgba(46, 204, 113, 0.2);
        }

        .beneficio-card:nth-child(3):hover {
            box-shadow: 0 20px 40px rgba(255, 159, 28, 0.2);
        }

        .beneficio-icon {
            font-size: 2rem;
            margin-bottom: 15px;
            display: block;
        }

        .beneficio-title {
            font-size: 1.15rem;
            font-weight: 600;
            margin-bottom: 15px;
            line-height: 1.3;
        }

        .beneficio-card:nth-child(1) .beneficio-title {
            color: var(--neon-cyan);
        }

        .beneficio-card:nth-child(2) .beneficio-title {
            color: var(--accent-green);
        }

        .beneficio-card:nth-child(3) .beneficio-title {
            color: var(--accent-orange);
        }

        .beneficio-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .disclaimer-box {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.05), rgba(0, 255, 249, 0.03));
            border: 2px dashed rgba(0, 212, 255, 0.3);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            margin-bottom: 40px;
            position: relative;
        }

        .disclaimer-icon {
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        .disclaimer-text {
            color: var(--text-primary);
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 10px;
        }

        .disclaimer-text strong {
            color: var(--neon-cyan);
        }

        .disclaimer-subtext {
            color: var(--accent-green);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .membresia-footer {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
            padding: 30px;
            text-align: center;
        }

        .membresia-footer-text {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .membresia-footer-text strong {
            color: var(--neon-cyan);
        }

        .membresia-footer-sub {
            color: var(--text-primary);
            font-size: 0.95rem;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .dashboard-section {
                grid-template-columns: 1fr;
            }
            .sensors-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .gauges-container {
                flex-direction: column;
            }
            .acciones-grid {
                grid-template-columns: repeat(3, 1fr);
            }
            .beneficios-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .hero-title { font-size: 2rem; }
            .countdown-value { font-size: 2rem; }
            .sensors-grid { grid-template-columns: 1fr; }
            .gauges-container { flex-direction: column; gap: 30px; }
            .gauge-wrapper { width: 220px; height: 220px; }
            
            /* Responsive módulos */
            .consciousness-section,
            .puentes-section,
            .transformacion-section,
            .membresia-section {
                padding: 60px 20px;
            }
            .consciousness-title,
            .puentes-title,
            .llave-title {
                font-size: 1.8rem;
            }
            .transformacion-title {
                font-size: 1.5rem;
            }
            .puente-item {
                flex-direction: column;
                text-align: center;
                padding: 20px;
            }
            .acciones-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
            .accion-card {
                padding: 20px 15px;
            }
            .cta-box {
                padding: 30px 20px;
            }
            .btn-activar {
                padding: 15px 30px;
                font-size: 1rem;
            }
            .membresia-container {
                padding: 40px 25px;
            }
            .beneficios-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
        }

        @media (max-width: 480px) {
            .acciones-grid {
                grid-template-columns: 1fr;
            }
        }
/* ============================================
   MÓDULO: ACTIVACIÓN / PAGOS
   ============================================ */

.activation-section {
    padding: 80px 40px;
    position: relative;
    z-index: 5;
}

.activation-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
}

.activation-header {
    margin-bottom: 50px;
}

.activation-title {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--neon-blue);
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.activation-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
}

/* Métodos de pago */
.payment-methods {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-bottom: 40px;
}

.payment-method {
    background: var(--glass);
    border: 1px solid rgba(0, 212, 255, 0.15);
    border-radius: 20px;
    padding: 35px 30px;
    position: relative;
    transition: all 0.4s ease;
}

.payment-method:hover {
    border-color: rgba(0, 212, 255, 0.4);
    box-shadow: 0 0 40px rgba(0, 212, 255, 0.1);
}

.payment-method.stripe {
    border-left: 4px solid #635BFF;
}

.payment-method.blockchain {
    border-left: 4px solid #8247E5;
}

.payment-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 20px;
}

.payment-label.stripe-label {
    color: #635BFF;
}

.payment-label.blockchain-label {
    color: #8247E5;
}

/* Botones placeholder */
.payment-button {
    display: inline-block;
    padding: 15px 40px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
}

.payment-button.stripe-btn {
    background: linear-gradient(135deg, #635BFF, #8B5CF6);
    color: white;
    box-shadow: 0 4px 20px rgba(99, 91, 255, 0.3);
}

.payment-button.stripe-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(99, 91, 255, 0.5);
}

.wallet-address {
    font-family: 'Courier New', monospace;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(130, 71, 229, 0.3);
    border-radius: 12px;
    padding: 18px 25px;
    font-size: 0.95rem;
    color: var(--text-primary);
    word-break: break-all;
    margin: 15px 0;
    position: relative;
}

.wallet-address::before {
    content: '💎';
    position: absolute;
    left: -10px;
    top: -10px;
    background: var(--bg-dark);
    padding: 5px;
    border-radius: 50%;
}

.blockchain-note {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 15px;
}

.polygon-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #8247E5;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s;
}

.polygon-link:hover {
    color: #A855F7;
    text-shadow: 0 0 15px rgba(130, 71, 229, 0.5);
}

/* Banner de beneficios */
.benefits-banner {
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(130, 71, 229, 0.1));
    border: 2px dashed rgba(0, 212, 255, 0.3);
    border-radius: 16px;
    padding: 25px 30px;
    margin-bottom: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
}

.benefits-text {
    font-size: 1rem;
    color: var(--text-primary);
    font-weight: 500;
}

.benefits-list {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
}

.benefit-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--text-secondary);
}

/* Acceso con código */
.code-access {
    background: var(--glass);
    border: 1px solid rgba(255, 195, 0, 0.2);
    border-radius: 20px;
    padding: 40px 35px;
    position: relative;
}

.code-access::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-yellow), var(--accent-orange));
    border-radius: 20px 20px 0 0;
}

.code-header {
    margin-bottom: 25px;
}

.code-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--accent-yellow);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.code-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
}

/* Botón Portal Pacto Azul */
.portal-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, var(--accent-yellow), var(--accent-orange));
    color: var(--bg-dark);
    padding: 18px 45px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    border: none;
    cursor: pointer;
    box-shadow: 0 5px 25px rgba(255, 159, 28, 0.4);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.portal-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s;
}

.portal-button:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 40px rgba(255, 159, 28, 0.6);
}

.portal-button:hover::before {
    left: 100%;
}

/* Responsive */
@media (max-width: 768px) {
    .activation-section {
        padding: 60px 20px;
    }
    
    .activation-title {
        font-size: 1.4rem;
        flex-direction: column;
        gap: 8px;
    }
    
    .payment-method {
        padding: 25px 20px;
    }
    
    .wallet-address {
        font-size: 0.8rem;
        padding: 15px;
    }
    
    .benefits-banner {
        flex-direction: column;
        text-align: center;
    }
    
    .portal-button {
        padding: 16px 30px;
        font-size: 1rem;
    }
}
    </style>
</head>
<body>
    <canvas id="particles-canvas"></canvas>

    <header>
        <div class="logo">
            <div class="logo-icon">🌍</div>
            <span>BlueSphere</span>
        </div>
        <nav>
            <a href="#">Inicio</a>
            <a href="#">Planeta</a>
            <a href="#">Manifiesto</a>
            <a href="#">Contacto</a>
        </nav>
    </header>

    <main class="main-container">
        <section class="hero-section">
            <p class="hero-subtitle">Observación Sistémica de la Salud Biofísica</p>
            <h1 class="hero-title">Indicadores Planetarios de Referencia <span class="highlight">+1.5°C</span></h1>
            <p class="hero-description">
                Marco inspirado en modelos científicos de estabilidad del sistema Tierra y los límites planetarios.
                Estimación basada en condiciones actuales para alcanzar el umbral crítico.
            </p>
            
            <!-- Botones de Escenario -->
            <div class="scenario-buttons">
                <button class="scenario-btn optimista">Optimista</button>
                <button class="scenario-btn intermedio active">Intermedio</button>
                <button class="scenario-btn critico">Crítico</button>
            </div>

            <!-- Status Global -->
            <div class="global-status">
                Salud Planetaria: <span class="value">62%</span> — Estado: INESTABLE
            </div>

            <!-- Countdown -->
            <div class="countdown-container">
                <div class="countdown">
                    <div class="countdown-item">
                        <div class="countdown-value" id="days">3563</div>
                        <div class="countdown-label">Días</div>
                    </div>
                    <div class="countdown-separator">:</div>
                    <div class="countdown-item">
                        <div class="countdown-value" id="hours">23</div>
                        <div class="countdown-label">Horas</div>
                    </div>
                    <div class="countdown-separator">:</div>
                    <div class="countdown-item">
                        <div class="countdown-value" id="minutes">59</div>
                        <div class="countdown-label">Minutos</div>
                    </div>
                    <div class="countdown-separator">:</div>
                    <div class="countdown-item">
                        <div class="countdown-value" id="seconds">25</div>
                        <div class="countdown-label">Segundos</div>
                    </div>
                </div>
            </div>
            <p class="countdown-legend">🌡️ Tiempo estimado para alcanzar el umbral crítico de +1.5°C</p>
        </section>

        <!-- SISTEMA ZIRIUX - HEPTAGRAMA (7 NODOS) -->
        <div class="ziriux-system">
            <!-- SVG para líneas de conexión -->
            <svg class="neural-network" viewBox="0 0 1400 700" preserveAspectRatio="xMidYMid meet">
                <defs>
                    <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
