<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>BlueSphere Oráculo</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: radial-gradient(circle at center, #0A1120, #05070A);
  color: white;
  text-align: center;
}

/* NÚCLEO */
.core {
  margin-top: 80px;
}

.circle {
  width: 220px;
  height: 220px;
  border-radius: 50%;
  border: 1px solid #00F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: auto;
  animation: pulse 4s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.percent {
  font-size: 48px;
  color: #00F0FF;
}

.label {
  font-size: 10px;
  letter-spacing: 3px;
  opacity: 0.6;
}

.timer {
  margin-top: 20px;
  color: #00F0FF;
  font-family: monospace;
}

/* SENSORES */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  max-width: 500px;
  margin: 40px auto;
}

.card {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(10px);
  border-radius: 15px;
  padding: 15px;
}

.card .value {
  color: #00F0FF;
  font-size: 20px;
}

/* MEMBRESÍAS */
.membership {
  margin-top: 60px;
}

.cards {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
}

.plan {
  width: 220px;
  padding: 20px;
  border-radius: 15px;
  background: rgba(255,255,255,0.05);
}

button {
  margin-top: 15px;
  padding: 10px;
  border: none;
  background: rgba(0,240,255,0.2);
  color: white;
  border-radius: 10px;
  cursor: pointer;
}
</style>
</head>

<body>

<div class="core">
  <div class="circle">
    <div>
      <div class="percent">--%</div>
      <div class="label">CONSCIENCIA PLANETARIA</div>
    </div>
  </div>

  <div class="timer">TIEMPO DE GRACIA: -- DÍAS</div>
</div>

<div class="grid">
  <div class="card"><div>AIRE</div><div class="value">--</div></div>
  <div class="card"><div>TEMP</div><div class="value">--</div></div>
  <div class="card"><div>ANTÁRTIDA</div><div class="value">--</div></div>
  <div class="card"><div>NIVEL MAR</div><div class="value">--</div></div>
  <div class="card"><div>ÁRTICO</div><div class="value">--</div></div>
  <div class="card"><div>OCÉANO</div><div class="value">--</div></div>
  <div class="card"><div>BIODIV.</div><div class="value">--</div></div>
</div>

<div class="membership">
  <h3>ACTIVACIÓN DE GUARDIÁN</h3>

  <div class="cards">
    <div class="plan">
      <h4>INICIAL</h4>
      <p>$10 USD</p>
      <button>ACTIVAR</button>
    </div>

    <div class="plan">
      <h4>ACTIVO</h4>
      <p>$25 USD</p>
      <button>ACTIVAR</button>
    </div>

    <div class="plan">
      <h4>GÉNESIS</h4>
      <p>$100 USD</p>
      <button>ACTIVAR</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>

<script>
const S_URL = 'https://ophicpcbgdgzthjamzoz.supabase.co';
const S_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9waGljcGNiZ2RnenRoamFtem96Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjQ3MjgwMzUsImV4cCI6MjA4MDMwNDAzNX0.K55Tk-cdbAFDOtGrIMN7vYFaJAccrsD6UdOrARt1P5c';

const supabaseClient = supabase.createClient(S_URL, S_KEY);

// -------- CARGA DE DATOS --------
async function cargardatos() {
  const { data, error } = await supabaseClient
    .from('heptagram_gaia_metrics')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(1)
    .single();

  if (error) {
    console.error('error:', error);
    return;
  }

  console.log('data:', data);

  // sensores reales
  const sensores = [
    data.aire,
    data.temperatura,
    data.hielo_antartida,
    data.nivel_mar,
    data.hielo_artico,
    data.oceano,
    data.biodiversidad
  ];

  // calcular conciencia si no existe
  let conciencia = data.conciencia_global;

  if (!conciencia) {
    const suma = sensores.reduce((a, b) => a + b, 0);
    conciencia = suma / sensores.length;
  }

  document.querySelector('.percent').innerText =
    Number(conciencia).toFixed(1) + '%';

  // días (si existe)
  if (data.dias_restantes) {
    document.querySelector('.timer').innerText =
      'TIEMPO DE GRACIA: ' + data.dias_restantes + ' DÍAS';
  }

  // pintar sensores
  const valores = document.querySelectorAll('.value');

  valores.forEach((el, i) => {
    if (sensores[i] !== undefined) {
      el.innerText = sensores[i];
    }
  });
}

// -------- REALTIME --------
function activarRealtime() {
  supabaseClient
    .channel('heptagram-live')
    .on('postgres_changes', {
      event: '*',
      schema: 'public',
      table: 'heptagram_gaia_metrics'
    }, payload => {
      console.log('cambio:', payload);
      cargardatos();
    })
    .subscribe();
}

// -------- INIT --------
cargardatos();
activarRealtime();
</script>

</body>
</html>
