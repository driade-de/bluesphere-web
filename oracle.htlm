    <script>
        // Sistema de partículas
        const canvas = document.getElementById('particles-canvas');
        const ctx = canvas.getContext('2d');
        
        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        const particles = [];
        const particleCount = 100;

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2;
                this.speedX = (Math.random() - 0.5) * 0.5;
                this.speedY = (Math.random() - 0.5) * 0.5;
                this.opacity = Math.random() * 0.5 + 0.2;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;

                if (this.x < 0) this.x = canvas.width;
                if (this.x > canvas.width) this.x = 0;
                if (this.y < 0) this.y = canvas.height;
                if (this.y > canvas.height) this.y = 0;
            }

            draw() {
                ctx.fillStyle = `rgba(0, 212, 255, ${this.opacity})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        for (let i = 0; i < particleCount; i++) {
            particles.push(new Particle());
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        // Countdown funcional
        function updateCountdown() {
            const targetDate = new Date('2035-12-31T23:59:59');
            const now = new Date();
            const diff = targetDate - now;

            if (diff > 0) {
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                document.getElementById('days').textContent = String(days).padStart(4, '0');
                document.getElementById('hours').textContent = String(hours).padStart(2, '0');
                document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
                document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
            }
        }

        setInterval(updateCountdown, 1000);
        updateCountdown();

        // Animación de barras al cargar
        window.addEventListener('load', () => {
            const bars = document.querySelectorAll('.sensor-bar-fill');
            bars.forEach((bar, index) => {
                const width = bar.style.width;
                bar.style.width = '0';
                setTimeout(() => {
                    bar.style.width = width;
                }, index * 100);
            });
        });

        // Cambio de escenarios
        document.querySelectorAll('.scenario-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                console.log('Escenario seleccionado:', this.textContent);
            });
        });

        // NAVEGACIÓN FLUIDA ENTRE MÓDULOS
        document.getElementById('btnConocerPuentes').addEventListener('click', function() {
            document.getElementById('puentes').scrollIntoView({ behavior: 'smooth' });
        });

        document.getElementById('btnVerImpacto').addEventListener('click', function() {
            document.getElementById('transformacion').scrollIntoView({ behavior: 'smooth' });
        });

        document.getElementById('btnActivarProtocolo').addEventListener('click', function() {
            document.getElementById('membresia').scrollIntoView({ behavior: 'smooth' });
        });

        // Función para cargar datos desde Supabase (ejemplo)
        async function loadSupabaseData() {
            // Ejemplo de cómo se conectaría:
            /*
            const { createClient } = await import('https://esm.sh/@supabase/supabase-js');
            const supabase = createClient(
                'TU_URL',
                'TU_ANON_KEY'
            );
            
            const { data: sensors, error } = await supabase
                .from('heptagram_gaia_metrics')
                .select('*')
                .order('updated_at', { ascending: false });
                
            if (sensors) {
                updateSensorsUI(sensors);
            }
            */
        }

        function updateSensorsUI(sensors) {
            sensors.forEach(sensor => {
                console.log(`Sensor: ${sensor.sensor_name}, Valor: ${sensor.value}, Estado: ${sensor.status}`);
            });
        }

        // Cargar datos cada 30 segundos (simulación)
        setInterval(() => {
            // loadSupabaseData();
            console.log('Actualizando datos...');
        }, 30000);
    </script>
